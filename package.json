{
  "name": "junior-frontend-test",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "react-task-manager",
    "react-native-user-list"
  ],
  "scripts": {
    "prepare": "husky",
    "dev:web": "bun run --cwd react-task-manager dev",
    "dev:mobile": "bun run --cwd react-native-user-list start",
    "dev:mobile:tunnel": "bun run --cwd react-native-user-list start:tunnel",
    "build:web": "bun run --cwd react-task-manager build",
    "lint": "bun run --cwd react-task-manager lint && bun run --cwd react-native-user-list lint",
    "typecheck": "bun run --cwd react-task-manager typecheck && bun run --cwd react-native-user-list typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit": "lint-staged && bun run typecheck",
    "commitlint": "commitlint"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
